# macOS
  .DS_Store
  **/.DS_Store

  # Python bytecode
  __pycache__/
  *.py[cod]
  *$py.class
  *.pyo

  # Distribution / build
  dist/
  build/
  *.egg-info/
  *.egg
  MANIFEST

  # Virtual environments
  .venv/
  venv/
  env/
  .env

  # Testing
  .pytest_cache/
  .coverage
  coverage.xml
  htmlcov/

  # Type checking / linting caches
  .mypy_cache/
  .ruff_cache/

  # Jupyter
  .ipynb_checkpoints/

  # Large data and model files in examples/
  examples/*.h5ad
  examples/*.h5
  examples/*.pt
  examples/data/

  # IDE
  .idea/
  .vscode/
  *.swp
  *.swo

  - Commit message: chore: add .gitignore
  - Click Commit changes
